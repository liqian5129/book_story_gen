# 微信读书 Cookie（从浏览器开发者工具中复制）
WEREAD_COOKIES=

# Kimi/Moonshot API Key（从 platform.moonshot.cn 获取）
KIMI_API_KEY=
KIMI_MODEL=kimi-k2

# Brave Search API Key（免费 2000次/月，从 brave.com/search/api 获取）
BRAVE_API_KEY=

# Volcengine TTS（豆包人声克隆，从 console.volcengine.com 获取）
VOLC_APPID=
VOLC_TOKEN=
VOLC_RESOURCE_ID=volc.megatts.voiceclone
VOLC_VOICE_TYPE=
# Volcengine TTS v3（视频逐场景合成 + 词级字幕）
# resource ID 与 v1 不同，按音色类型选择（和 VOLC_VOICE_TYPE 的音色体系对应）：
#   内置精品音色（*_bigtts）→ seed-tts-1.0
#   豆包2.0音色             → seed-tts-2.0
#   声音复刻1.0             → seed-icl-1.0
#   声音复刻2.0             → seed-icl-2.0
VOLC_V3_RESOURCE_ID=seed-tts-1.0

# 素材图片来源（wikimedia / brave，默认 wikimedia）
# brave：复用 BRAVE_API_KEY，需订阅含图片搜索的 Search 计划
IMAGE_SEARCH_PROVIDER=wikimedia

# Remotion 视频合成（Phase 2）
# REMOTION_PROJECT_DIR=/path/to/remotion/project

# 服务端口（默认 8888）
PORT=8888
